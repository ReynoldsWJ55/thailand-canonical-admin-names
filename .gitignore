# Local-development scratch
scratch/
notebooks/

# Do NOT ignore the cached upstream inputs at data/inputs/ — they are part of
# the build's reproducibility guarantee and must be tracked. The .gitignore
# entries above target editor/OS/Python detritus, not project content.

# Build intermediates (regeneratable via bin/build_methodology.py)
methodology/build/_thai_header.tex
methodology/build/_thai_fallback.tex
methodology/build/methodology-v*-pdf.md

# Smoke-test working directory (uses /tmp by default; safety belt)
data/v*/*_smoke_snapshot/

# Internal workstream brief (maintainer-only planning notes)
00-workstream-brief.md
methodology/outline.md
